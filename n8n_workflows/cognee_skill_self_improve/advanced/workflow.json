    },
    {
      "parameters": {
        "jsCode": "const diff = $json.skill_diff || '';\nconst skill = $json.skill_to_improve || 'unknown-skill';\nconst proposal = $json.proposal_id || 'unknown-proposal';\nconst markdown = [\n  `## Skill Delta: ${skill}`,\n  '',\n  `Proposal: ${proposal}`,\n  `Applied: ${$json.applied === true}`,\n  `Skill file: ${$json.skill_file || ''}`,\n  '',\n  '```diff',\n  diff || '# No diff returned by the runner.',\n  '```',\n].join('\\n');\nreturn [{\n  json: {\n    status: $json.status,\n    skill_to_improve: skill,\n    proposal_id: proposal,\n    applied: $json.applied,\n    score: $json.score,\n    score_threshold: $json.score_threshold,\n    skill_file: $json.skill_file,\n    skill_delta: diff,\n    skill_delta_markdown: markdown,\n  }\n}];"
      },
      "id": "5c5ba359-8071-4cbf-99fa-59f6d2792536",
      "name": "Show Skill Delta",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3240,
        -220
      ]
    },
    {
      "parameters": {
        "jsCode": "return [{ json: { status: 'waiting_for_review', proposal_id: $json.proposal_id, skill_to_improve: $json.skill_to_improve, message: 'Proposal generated but not approved. Replace Demo Controls with Slack, GitHub, or Wait-for-webhook approval for production.' } }];"
      },
      "id": "a2f5eb18-8210-4db1-9256-ae4cd6cf5316",
