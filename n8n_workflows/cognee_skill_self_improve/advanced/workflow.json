    },
    {
      "parameters": {
        "jsCode": "const runner = '\"${COGNEE_SELF_IMPROVE_WORKFLOW_ROOT:-./n8n_workflows/cognee_skill_self_improve/advanced}/run_n8n_action.sh\"';\nconst quote = (value) => `'${String(value).replace(/'/g, `'\\\\''`)}'`;\nconst command = [\n  `COGNEE_SKILL_NAME=${quote($json.skill_name)}`,\n  `COGNEE_SKILL_SCORE=${quote($json.eval_score)}`,\n  `COGNEE_SKILL_SCORE_THRESHOLD=${quote($json.score_threshold)}`,\n  `COGNEE_SELF_IMPROVE_APPROVED=${quote($json.approved)}`,\n  `COGNEE_SELF_IMPROVE_APPLY=${quote($json.apply)}`,\n  `COGNEE_SELF_IMPROVE_SYNC_FILE=${quote($json.sync_file)}`,\n  runner,\n  'init-state',\n].join(' ');\nreturn [{ json: { ...$json, command } }];"
      },
      "id": "cad48eb3-df36-4492-8acf-c2daf6ac0017",
      "name": "Build Init Command",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -360,
        0
      ]
    },
    {
      "parameters": {
        "command": "={{$json.command}}"
      },
      "id": "dd565b09-aa5a-44c8-90e5-c6f9f13feeb7",
      "name": "Init Run State",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        -120,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const raw = $json.stdout || '';\nconst start = raw.indexOf('{');\nconst end = raw.lastIndexOf('}');\nif (start === -1 || end < start) throw new Error(`No JSON object found in stdout: ${raw}`);\nconst parsed = JSON.parse(raw.slice(start, end + 1));\nreturn [{ json: { ...parsed, stderr: $json.stderr, exitCode: $json.exitCode } }];"
      },
